generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Canteen {
  id      Int           @id @default(autoincrement())
  name    String
  ratings Float?
  imageUrl String?
  items   CanteenItem[]
  carts   Cart[]
  orders  Order[]
  cashiers Cashier[]
  prebooks Prebook[]
}

model CanteenItem {
  id        Int        @id @default(autoincrement())
  name      String
  price     Float
  rating    Float?
  foodType  FoodType     @default(VEG)
  category  ItemCategory @default(OTHER)
  imageUrl  String?
  canteenId Int
  canteen   Canteen    @relation(fields: [canteenId], references: [id], onDelete: Cascade)
  cartItems CartItem[]
  orderItems OrderItem[]
  prebookItems PrebookItem[]

  @@index([canteenId])
}

enum FoodType {
  VEG
  NON_VEG
}

enum ItemCategory {
  RICE
  CURRIES
  ICECREAM
  ROOTI
  DRINKS
  OTHER
}

model Student {
  id         Int     @id @default(autoincrement())
  name       String
  email      String  @unique
  number     String?
  branch     String?
  rollNumber String?
  password   String?
  carts      Cart[]
  orders     Order[]
  prebooks   Prebook[]
}

model Admin {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Cashier {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  canteenId Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  canteen   Canteen  @relation(fields: [canteenId], references: [id], onDelete: Cascade)
  orders    Order[]

  @@index([canteenId])
}

model Cart {
  id        Int        @id @default(autoincrement())
  studentId Int
  canteenId Int
  total     Float      @default(0)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  student   Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  canteen   Canteen    @relation(fields: [canteenId], references: [id], onDelete: Cascade)
  items     CartItem[]

  @@unique([studentId])
  @@index([canteenId])
}

model CartItem {
  id           Int         @id @default(autoincrement())
  cartId       Int
  canteenItemId Int
  quantity     Int         @default(1)
  cart         Cart        @relation(fields: [cartId], references: [id], onDelete: Cascade)
  canteenItem  CanteenItem @relation(fields: [canteenItemId], references: [id], onDelete: Cascade)

  @@unique([cartId, canteenItemId])
  @@index([cartId])
  @@index([canteenItemId])
}

enum OrderStatus {
  CREATED
  PAID
  READY
  DELIVERED
  FAILED
  CANCELLED
  REFUNDED
}

model Order {
  id            Int         @id @default(autoincrement())
  orderId       String      @unique
  transactionId String?     @unique
  status        OrderStatus @default(CREATED)
  total         Float
  currency      String      @default("INR")
  tokenNumber   Int?
  isPrebooked   Boolean     @default(false)
  scheduledFor  DateTime?
  studentId     Int?
  cashierId     Int?
  canteenId     Int
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  student       Student?    @relation(fields: [studentId], references: [id], onDelete: SetNull)
  cashier       Cashier?    @relation(fields: [cashierId], references: [id], onDelete: SetNull)
  canteen       Canteen     @relation(fields: [canteenId], references: [id], onDelete: Cascade)
  items         OrderItem[]

  @@index([studentId])
  @@index([cashierId])
  @@index([canteenId])
  @@index([canteenId, scheduledFor])
}

model OrderItem {
  id            Int         @id @default(autoincrement())
  orderId       Int
  canteenItemId Int
  quantity      Int
  price         Float
  total         Float
  status        OrderItemStatus @default(PENDING)
  order         Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  canteenItem   CanteenItem @relation(fields: [canteenItemId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([canteenItemId])
}

enum OrderItemStatus {
  PENDING
  IN_PROGRESS
  DELAYED
  READY
  DELIVERED
}

enum PrebookStatus {
  PENDING_PAYMENT
  CONFIRMED
  EXPIRED
  CANCELLED
}

model Prebook {
  id              Int           @id @default(autoincrement())
  studentId       Int
  canteenId       Int
  slotStart       DateTime
  slotEnd         DateTime
  status          PrebookStatus @default(PENDING_PAYMENT)
  total           Float
  currency        String        @default("INR")
  razorpayOrderId String?       @unique
  expiresAt       DateTime
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  student         Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  canteen         Canteen       @relation(fields: [canteenId], references: [id], onDelete: Cascade)
  items           PrebookItem[]

  @@index([studentId])
  @@index([canteenId, slotStart])
}

model PrebookItem {
  id            Int         @id @default(autoincrement())
  prebookId     Int
  canteenItemId Int
  quantity      Int
  price         Float
  total         Float
  prebook       Prebook     @relation(fields: [prebookId], references: [id], onDelete: Cascade)
  canteenItem   CanteenItem @relation(fields: [canteenItemId], references: [id], onDelete: Cascade)

  @@index([prebookId])
  @@index([canteenItemId])
}
